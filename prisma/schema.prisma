// USOAP CMA Tracker schema
//
// Postgres for dev and prod. Local dev runs Postgres via docker compose
// (see docker-compose.yml); prod runs on any managed Postgres (Vercel
// Postgres, Neon, Supabase, etc.).
//
// DATABASE_URL is the pooled connection used at runtime. DIRECT_URL bypasses
// the pooler and is used by Prisma Migrate. Both point at the same database;
// for Docker dev they can be identical because there's no pgbouncer in the
// way. Pooled hosts (Neon, Vercel Postgres) require them to differ.

generator client {
  provider      = "prisma-client-js"
  // `native` keeps dev fast on whatever host the developer is on; the rhel
  // target covers Vercel's AL2023 runtime. Without the rhel target Prisma
  // can fail to locate the query engine binary on Vercel after a cache hit.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// A single Protocol Question. Fields A-G come from the ICAO source sheet
// (immutable, never edited by OCAA). Fields H+ are OCAA response fields.
model ProtocolQuestion {
  id                   String  @id @default(cuid())
  // Audit area the PQ belongs to. "PEL" for now. Future: LEG, ORG, OPS, AIR, AIG, ANS, AGA.
  auditArea            String  @default("PEL")
  pqNo                 String  @unique // e.g. "3.001"
  ce                   String // e.g. "CE-2"
  question             String
  // JSON-encoded string[]. Kept as a TEXT column (not Postgres JSONB) because
  // the guidance / ICAO reference arrays are small, write-once on seed, and
  // never queried into. Using TEXT keeps the seed payload shape trivial and
  // matches what the app already expects via `hydratePQ` in src/lib/types.ts.
  guidanceJson         String  @default("[]")
  icaoReferencesJson   String  @default("[]")
  isPPQ                Boolean @default(false)
  isATC                Boolean @default(false)
  amendmentDescription String?

  // OCAA response fields (columns H-P in the source)
  status                 Status  @default(NOT_STARTED)
  statusOfImplementation String?
  mainResponsibility     String?
  partResponsibility     String?
  fcl                    String?
  aw                     String?
  atc                    String?
  med                    String?
  workRequired           String?
  briefOnWorkRequired    String?
  internalNotes          String?

  evidenceLinks    EvidenceLink[]
  statusHistory    StatusHistory[]
  fieldSubmissions FieldSubmission[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("PQUpdatedBy", fields: [updatedById], references: [id])

  @@index([ce])
  @@index([status])
  @@index([isPPQ])
  @@index([isATC])
  @@index([auditArea])
}

enum Status {
  NOT_STARTED
  IN_PROGRESS
  NEEDS_WORK
  UNDER_REVIEW
  COMPLETE
}

// Evidence attached to a PQ. Usually a URL to a document in OCAA's DMS,
// SharePoint, or a regulation portal. We also allow inline descriptions.
model EvidenceLink {
  id          String           @id @default(cuid())
  pq          ProtocolQuestion @relation(fields: [pqId], references: [id], onDelete: Cascade)
  pqId        String
  label       String
  url         String
  description String?
  createdAt   DateTime         @default(now())
  createdById String?
  createdBy   User?            @relation("EvidenceCreatedBy", fields: [createdById], references: [id])

  // Admin sign-off. Unlike FieldSubmission (one-approved-per-thread),
  // evidence approval is per-item: every attached link is validated
  // independently by an admin, so multiple evidences on the same PQ can
  // be approved at once.
  approvedAt   DateTime?
  approvedById String?
  approvedBy   User?     @relation("EvidenceApprover", fields: [approvedById], references: [id])

  @@index([pqId])
  @@index([approvedAt])
}

// FieldSubmission: append-only comment-thread for every editable OCAA response
// field on a PQ. A "save" produces a new row. Past submissions are never
// edited; revisions create a new submission that references the predecessors
// via `revisesIdsJson`. Exactly one submission per (pqId, fieldKey) can be
// marked approved at a time (enforced in the service layer, since SQL partial
// unique indexes on booleans are awkward across DBs).
model FieldSubmission {
  id       Int              @id @default(autoincrement())
  pq       ProtocolQuestion @relation(fields: [pqId], references: [id], onDelete: Cascade)
  pqId     String
  fieldKey FieldKey
  seq      Int // per (pqId, fieldKey), starts at 1

  value          String
  revisesIdsJson String @default("[]") // JSON array of FieldSubmission.id

  author   User   @relation("SubmissionAuthor", fields: [authorId], references: [id])
  authorId String
  // Optional display-name override. Used when the original attribution
  // (e.g. a parenthetical "(Imtiaz)" in a source cell) doesn't map to a
  // real user in the system. When set, the UI prefers this string over
  // the joined author.name but does NOT grant admin styling.
  authorLabel String?

  approvedAt   DateTime?
  approvedBy   User?     @relation("SubmissionApprover", fields: [approvedById], references: [id])
  approvedById String?

  createdAt DateTime @default(now())

  // Marks a submission imported from the source workbook as part of the
  // immutable initial template. These rows cannot be deleted, and the
  // reset-to-initial tool preserves them. They can still be revised: a
  // revision creates a new (non-initial) submission that references the
  // initial one via revisesIdsJson.
  isInitial Boolean @default(false)

  @@unique([pqId, fieldKey, seq])
  @@index([pqId, fieldKey, createdAt])
  @@index([approvedAt])
  @@index([isInitial])
}

enum FieldKey {
  STATUS_OF_IMPLEMENTATION
  MAIN_RESPONSIBILITY
  PART_RESPONSIBILITY
  FCL
  AW
  ATC
  MED
  FOO
  SMS
  WORK_REQUIRED
  BRIEF_ON_WORK_REQUIRED
  INTERNAL_NOTES
  OCAA_FINAL_RESPONSE
}

// Audit trail for status changes. One row per transition.
model StatusHistory {
  id          String           @id @default(cuid())
  pq          ProtocolQuestion @relation(fields: [pqId], references: [id], onDelete: Cascade)
  pqId        String
  fromStatus  Status?
  toStatus    Status
  note        String?
  changedAt   DateTime         @default(now())
  changedById String?
  changedBy   User?            @relation("HistoryChangedBy", fields: [changedById], references: [id])

  @@index([pqId])
  @@index([changedAt])
}

// Lightweight user. Plug in NextAuth later and keep this as the profile record.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())

  pqUpdates        ProtocolQuestion[] @relation("PQUpdatedBy")
  evidenceCreated  EvidenceLink[]     @relation("EvidenceCreatedBy")
  evidenceApproved EvidenceLink[]     @relation("EvidenceApprover")
  statusChanges    StatusHistory[]    @relation("HistoryChangedBy")

  submissionsAuthored FieldSubmission[] @relation("SubmissionAuthor")
  submissionsApproved FieldSubmission[] @relation("SubmissionApprover")

  @@index([role])
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}
