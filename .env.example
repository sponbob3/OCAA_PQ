# Local Postgres via `docker compose up -d`. See docker-compose.yml.
DATABASE_URL="postgresql://usoap:usoap@localhost:5432/usoap?schema=public"
DIRECT_URL="postgresql://usoap:usoap@localhost:5432/usoap?schema=public"

# Vercel / Neon / Supabase example (keep pooled and direct URLs separate).
# DATABASE_URL is the pooled (pgbouncer) connection used at runtime.
# DIRECT_URL bypasses the pooler and is used by Prisma Migrate.
#
# DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DB?sslmode=require&pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# -----------------------------------------------------------------
# ICVM PDF report header. Shown at the top of every /api/pqs/*/pdf.
# Override per audit so we don't have to edit source for every run.
# All four are optional; if unset, the month/year default to the
# server's current month/year and the other two to their usual values.
# -----------------------------------------------------------------
# AUDIT_NAME="ICAO ICVM"
# AUDIT_MONTH="NOVEMBER"
# AUDIT_YEAR="2023"
# AUDIT_OFFICE="CAA/DGCAR PERSONNEL LICENSING OFFICE (FSD)"
# AUDIT_FOOTER_PREFIX="ICVM PQ"

# -----------------------------------------------------------------
# Site passcode gate. The root page (/) asks for this before letting
# visitors reach the login page. If unset, falls back to the preview
# default baked into src/app/page.tsx (currently "tarbela1964").
# -----------------------------------------------------------------
# SITE_PASSCODE="tarbela1964"
