# Local Postgres via `docker compose up -d`. See docker-compose.yml.
DATABASE_URL="postgresql://usoap:usoap@localhost:5432/usoap?schema=public"
DIRECT_URL="postgresql://usoap:usoap@localhost:5432/usoap?schema=public"

# Vercel / Neon / Supabase example (keep pooled and direct URLs separate).
# DATABASE_URL is the pooled (pgbouncer) connection used at runtime.
# DIRECT_URL bypasses the pooler and is used by Prisma Migrate.
#
# DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DB?sslmode=require&pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"
