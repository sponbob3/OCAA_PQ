{
  "name": "usoap-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx scripts/seed.ts",
    "backfill": "tsx scripts/backfill-from-defaults.ts",
    "reset-to-initial": "tsx scripts/reset-to-initial.ts",
    "import-excel": "tsx scripts/import-excel.ts",
    "db:reset": "prisma migrate reset --force && npm run seed",
    "db:migrate": "prisma migrate deploy",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "engines": {
    "node": ">=20.11 <23"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "@react-pdf/renderer": "^4.5.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "prisma": "^6.3.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "xlsx": "^0.18.5"
  }
}
